{
  "name": "markdown-power-tools",
  "displayName": "Markdown Power Tools",
  "description": "Markdown作業効率化拡張 — 画像貼り付け・構文テンプレ挿入",
  "version": "0.1.0",
  "license": "MIT",
  "publisher": "local",
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Markdown Power Tools",
      "properties": {
        "mdPowerTools.image.saveLocationMode": {
          "type": "string",
          "default": "relative",
          "enum": ["relative", "workspace"],
          "description": "画像保存先の基準。relative=Markdownファイル基準、workspace=ワークスペースルート基準"
        },
        "mdPowerTools.image.saveFolder": {
          "type": "string",
          "default": "assets",
          "description": "画像保存先フォルダ名"
        },
        "mdPowerTools.image.altTextMode": {
          "type": "string",
          "default": "prompt",
          "enum": ["prompt", "empty", "filename"],
          "description": "altテキストの設定。prompt=プレースホルダで編集可能、empty=空、filename=ファイル名自動"
        }
      }
    },
    "commands": [
      {
        "command": "mdPowerTools.insertTable",
        "title": "%command.insertTable%",
        "enablement": "editorLangId == markdown"
      },
      {
        "command": "mdPowerTools.insertCodeBlock",
        "title": "%command.insertCodeBlock%",
        "enablement": "editorLangId == markdown"
      },
      {
        "command": "mdPowerTools.insertChecklist",
        "title": "%command.insertChecklist%",
        "enablement": "editorLangId == markdown"
      },
      {
        "command": "mdPowerTools.insertDetails",
        "title": "%command.insertDetails%",
        "enablement": "editorLangId == markdown"
      },
      {
        "command": "mdPowerTools.insertBlockquote",
        "title": "%command.insertBlockquote%",
        "enablement": "editorLangId == markdown"
      },
      {
        "command": "mdPowerTools.insertMermaidFlowchart",
        "title": "%command.insertMermaidFlowchart%",
        "enablement": "editorLangId == markdown"
      },
      {
        "command": "mdPowerTools.insertMermaidSequence",
        "title": "%command.insertMermaidSequence%",
        "enablement": "editorLangId == markdown"
      },
      {
        "command": "mdPowerTools.insertMermaidEr",
        "title": "%command.insertMermaidEr%",
        "enablement": "editorLangId == markdown"
      },
      {
        "command": "mdPowerTools.insertMermaidState",
        "title": "%command.insertMermaidState%",
        "enablement": "editorLangId == markdown"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "mdPowerTools.submenu",
          "group": "mdPowerTools",
          "when": "editorLangId == markdown"
        }
      ],
      "mdPowerTools.submenu": [
        { "command": "mdPowerTools.insertTable", "group": "2_markdown" },
        { "command": "mdPowerTools.insertCodeBlock", "group": "2_markdown" },
        { "command": "mdPowerTools.insertChecklist", "group": "2_markdown" },
        { "command": "mdPowerTools.insertDetails", "group": "2_markdown" },
        { "command": "mdPowerTools.insertBlockquote", "group": "2_markdown" },
        { "command": "mdPowerTools.insertMermaidFlowchart", "group": "3_mermaid" },
        { "command": "mdPowerTools.insertMermaidSequence", "group": "3_mermaid" },
        { "command": "mdPowerTools.insertMermaidEr", "group": "3_mermaid" },
        { "command": "mdPowerTools.insertMermaidState", "group": "3_mermaid" }
      ]
    },
    "submenus": [
      {
        "id": "mdPowerTools.submenu",
        "label": "%submenu.label%"
      }
    ]
  },
  "scripts": {
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify --sourcemap",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npx @vscode/vsce package --no-dependencies --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.97.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  }
}
